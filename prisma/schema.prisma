datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(uuid())
  pin            String   @unique
  dailyLimit     Int      @default(1000)
  usedToday      Int      @default(0)
  lastResetDate  DateTime @default(now())
  createdAt      DateTime @default(now())
}